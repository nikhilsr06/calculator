{
  "$schema": "https://schema.tauri.app/config/1.0.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Formula Calculator",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false },
      "http": {
        "all": true,
        "scope": ["http://localhost:4000/**", "https://**"]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.company.formula-calculator",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png"
      ],
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Engineering Formula Calculator",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ]
  }
}
